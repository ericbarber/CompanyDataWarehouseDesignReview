			{
				"name": "upsert UserMenu records",
				"description": "execute the stored procedure to merge records from the temp table into the target table",
				"type": "Lookup",
				"dependsOn": [
					{
						"activity": "insert to temp table",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "/****** Script used to upsert records from the temp table *****/\nMERGE dbo.UserMenu AS TARGET\n    USING dbo.UserMenuStaging  AS SOURCE\n    ON (\n\t\tTARGET.Email = SOURCE.Email\n\t\tAND TARGET.WorkspaceID = SOURCE.WorkspaceID\n\t\tAND TARGET.ReportID = SOURCE.ReportID\n\t\tAND TARGET.ProjectNumber = SOURCE.ProjectNumber\n        AND target.IsOverride = 1\n        AND source.IsOverride = 1\n)\n    WHEN MATCHED\n\t--update existing values\n    THEN UPDATE\n         SET \n           TARGET.Email = SOURCE.Email,\n\t\t   TARGET.WorkspaceID = SOURCE.WorkspaceID,\n\t\t   TARGET.ReportID = SOURCE.ReportID,\n\t\t   TARGET.ProjectNumber = SOURCE.ProjectNumber,\n           TARGET.isOverride = SOURCE.isOverride\n\t--insert new values\n    WHEN NOT MATCHED BY TARGET\n    THEN INSERT (Email, WorkspaceID, ReportID, ProjectNumber,IsOverride)         \n         VALUES (\n\t\t SOURCE.Email\n\t\t,SOURCE.WorkspaceID\n\t\t,SOURCE.ReportID\n\t\t,SOURCE.ProjectNumber\n        ,SOURCE.isOverride);\n\n-- select values so lookup activity doesnt fail\nSELECT COUNT(*) FROM dbo.UserMenu WHERE IsOverride = 1",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "dsAsqlSqlAuthSdatWebApp",
						"type": "DatasetReference",
						"parameters": {
							"schemaName": "dbo",
							"tableName": "UserMenuStaging"
						}
					}
				}
			},
