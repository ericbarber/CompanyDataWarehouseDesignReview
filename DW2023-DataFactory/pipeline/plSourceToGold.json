						"dependencyConditions": [
							"Completed"
						]
					},
					{
						"activity": "GRAPHQL API",
						"dependencyConditions": [
							"Completed"
						]
					},
					{
						"activity": "CSLB",
						"dependencyConditions": [
							"Completed"
						]
