					{
						"activity": "VRM",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "CurrentMSTTime",
					"value": {
						"value": "@convertTimeZone(utcNow(), 'UTC', 'US Mountain Standard Time')\n",
						"type": "Expression"
					}
				}
			},
			{
				"name": "CurrentPeriod",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "CurrentMSTTime",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "CurrentPeriod",
					"value": {
						"value": "@formatDateTime(variables('CurrentMSTTime'), 'tt')\n",
						"type": "Expression"
					}
				}
			},
			{
				"name": "NextMSTMidnight",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "CurrentPeriod",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "NextMSTMidnight",
					"value": {
						"value": "@concat(\n  formatDateTime(\n    addDays(\n      convertTimeZone(utcNow(), 'UTC', 'US Mountain Standard Time'),\n      1\n    ),\n    'yyyy-MM-dd'\n  ),\n  'T00:05:00'\n)\n",
						"type": "Expression"
					}
				}
			},
			{
				"name": "WaitTimeSeconds",
				"type": "SetVariable",
				"dependsOn": [
					{
						"activity": "NextMSTMidnight",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"policy": {
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"variableName": "WaitTimeSeconds",
					"value": {
						"value": "@if(\n    equals(variables('CurrentPeriod'), 'PM'),\n    div(\n        sub(\n            ticks(variables('NextMSTMidnight')),\n            ticks(variables('CurrentMSTTime'))\n        ),\n        10000000\n    ),\n    0\n)\n",
						"type": "Expression"
					}
				}
			},
			{
				"name": "If Condition1",
				"type": "IfCondition",
				"dependsOn": [
					{
						"activity": "WaitTimeSeconds",
						"dependencyConditions": [
							"Completed"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"expression": {
						"value": "@greater(variables('WaitTimeSeconds'), 0)\n",
						"type": "Expression"
					},
					"ifTrueActivities": [
						{
							"name": "Wait",
							"type": "Wait",
							"dependsOn": [],
							"userProperties": [],
							"typeProperties": {
								"waitTimeInSeconds": {
