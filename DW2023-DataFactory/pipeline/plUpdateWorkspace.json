{
	"name": "plUpdateWorkspace",
	"properties": {
		"description": "pipeline used to update the workspace table in the Azure SQL database used by the web app",
		"activities": [
			{
				"name": "insert to temp table",
				"type": "Copy",
				"dependsOn": [
					{
						"activity": "log pipeline start",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "ParquetSource",
						"storeSettings": {
							"type": "AzureBlobFSReadSettings",
							"recursive": true,
							"wildcardFolderPath": "pbi_workspace_reports_export",
							"wildcardFileName": "*.parquet",
							"enablePartitionDiscovery": false
						},
						"formatSettings": {
							"type": "ParquetReadSettings"
						}
					},
					"sink": {
						"type": "AzureSqlSink",
						"preCopyScript": "DROP TABLE IF EXISTS \ndbo.WorkspacesStaging",
						"writeBehavior": "insert",
						"sqlWriterUseTableLock": false,
						"tableOption": "autoCreate",
						"disableMetricsCollection": false
					},
					"enableStaging": false,
					"translator": {
						"type": "TabularTranslator",
						"mappings": [
							{
								"source": {
									"name": "workspace_id",
									"physicalType": "UTF8"
								},
								"sink": {
									"name": "WorkspaceID",
									"type": "String",
									"physicalType": "varchar"
								}
							},
							{
								"source": {
									"name": "report_id",
									"physicalType": "UTF8"
								},
								"sink": {
									"name": "ReportID",
									"physicalType": "varchar"
								}
							},
							{
								"source": {
									"name": "workspace_friendly_name",
									"physicalType": "UTF8"
								},
								"sink": {
									"name": "workspacename",
									"physicalType": "varchar"
								}
							},
							{
								"source": {
									"name": "report_name"
								},
								"sink": {
									"name": "reportname"
								}
							}
						],
						"typeConversion": true,
						"typeConversionSettings": {
							"allowDataTruncation": true,
							"treatBooleanAsNumber": false
						}
					}
				},
				"inputs": [
					{
						"referenceName": "dsAdlsManagedIdentityParquet",
						"type": "DatasetReference",
						"parameters": {
							"containerName": "adf-staging",
							"folderPath": "pbi_workspace_reports_export",
							"fileName": "*.parquet"
						}
					}
				],
				"outputs": [
					{
						"referenceName": "dsAsqlSqlAuthSdatWebApp",
						"type": "DatasetReference",
						"parameters": {
							"schemaName": "dbo",
							"tableName": "workspacesStaging"
						}
					}
				]
			},
			{
				"name": "upsert workspace records",
				"description": "merge records from workspace staging temp tableto workspace table",
				"type": "Lookup",
				"dependsOn": [
					{
						"activity": "delete user menu records",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "/****** Script used to upsert records from the temp table *****/\nMERGE dbo.Workspaces AS TARGET\n    USING dbo.WorkspacesStaging  AS SOURCE\n    ON (TARGET.WorkspaceId = SOURCE.WorkspaceId\n\t\tAND TARGET.ReportId = SOURCE.ReportId\n                AND TARGET.WorkspaceName = SOURCE.WorkspaceName)\n    WHEN MATCHED\n\t--update existing values\n    THEN UPDATE\n         SET TARGET.WorkspaceId = SOURCE.WorkspaceId,\n         TARGET.ReportId = SOURCE.ReportId,\n\t\t TARGET.WorkspaceName = SOURCE.WorkspaceName,\n\t\t TARGET.ReportName = SOURCE.ReportName\n\t--insert new values\n    WHEN NOT MATCHED BY TARGET\n    THEN INSERT (WorkspaceId, ReportId, WorkspaceName, ReportName)         \n         VALUES (SOURCE.WorkspaceId\n\t\t,SOURCE.ReportId\n\t\t,SOURCE.WorkspaceName\n\t\t,SOURCE.ReportName)\n\t\n--when not matched by source, delete the record\n    WHEN NOT MATCHED BY SOURCE\n    THEN DELETE;\n\n--cleanup staging table\nDROP TABLE IF EXISTS dbo.WorkspacesStaging;\n\n\nSELECT * FROM dbo.Workspaces",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "dsAsqlSqlAuthSdatWebApp",
						"type": "DatasetReference",
						"parameters": {
							"schemaName": "dbo",
							"tableName": "workspaces"
						}
					}
				}
			},
