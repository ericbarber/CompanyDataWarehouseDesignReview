			{
				"name": "error notification 2",
				"description": "log error and notify users if notifications are enabled",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "insert to temp table",
						"dependencyConditions": [
							"Failed"
						]
					},
					{
						"activity": "upsert workspace records",
						"dependencyConditions": [
							"Failed"
						]
					},
					{
						"activity": "delete user menu records",
						"dependencyConditions": [
							"Failed"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "plLogMsgAndSendEmail",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
