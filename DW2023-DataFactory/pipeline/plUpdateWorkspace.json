			{
				"name": "delete user menu records",
				"description": "delete records from dbo.UserMenu that will violate the FK constraint against dbo.Workspaces that says the WorkspaceID and ReportID must be in dbo.Workspaces",
				"type": "Lookup",
				"dependsOn": [
					{
						"activity": "insert to temp table",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"timeout": "0.12:00:00",
					"retry": 1,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": "/****** Script used to delete records from dbo.UserMenu table *****/\n\nBEGIN TRANSACTION\n\nDELETE FROM dbo.UserMenu\nWHERE NOT EXISTS (\n    SELECT 1\n    FROM dbo.WorkspacesStaging as source\n    WHERE dbo.UserMenu.WorkspaceID = source.WorkspaceID \nAND dbo.UserMenu.ReportID = source.ReportID\n);\n\nCOMMIT TRANSACTION;\n\n-- return results so lookup doesn't fail\nSELECT COUNT(*) FROM dbo.UserMenu",
						"queryTimeout": "02:00:00",
						"partitionOption": "None"
					},
					"dataset": {
						"referenceName": "dsAsqlSqlAuthSdatWebApp",
						"type": "DatasetReference",
						"parameters": {
							"schemaName": "dbo",
							"tableName": "workspaces"
						}
					}
				}
