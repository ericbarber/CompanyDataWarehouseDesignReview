					"isSequential": true,
					"activities": [
						{
							"name": "copy activity events",
							"description": "copy activity events from api to sink json file",
							"type": "Copy",
							"dependsOn": [
								{
									"activity": "log item start",
									"dependencyConditions": [
										"Succeeded"
									]
								}
							],
							"policy": {
