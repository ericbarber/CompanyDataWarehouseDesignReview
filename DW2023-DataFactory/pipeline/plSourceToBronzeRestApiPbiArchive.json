								"secureOutput": false,
								"secureInput": false
							},
							"userProperties": [],
							"typeProperties": {
								"source": {
									"type": "RestSource",
									"additionalColumns": [
										{
											"name": "etl_raw_timestamp",
											"value": {
												"value": "@variables('utcTimestamp')",
												"type": "Expression"
											}
										},
										{
											"name": "etl_datasource_name",
											"value": {
												"value": "@activity('lookup objects').output.firstRow.dataSourceName",
												"type": "Expression"
											}
										}
									],
									"httpRequestTimeout": "00:01:40",
									"requestInterval": "00.00:00:00.010",
									"requestMethod": "GET",
									"paginationRules": {
										"AbsoluteUrl": {
											"value": "$.continuationUri",
											"type": "Expression"
										}
									}
								},
								"sink": {
									"type": "JsonSink",
									"storeSettings": {
										"type": "AzureBlobFSWriteSettings"
									},
									"formatSettings": {
										"type": "JsonWriteSettings"
									}
								},
								"enableStaging": false
							},
							"inputs": [
								{
									"referenceName": "dsRestApiManagedIdentity",
									"type": "DatasetReference",
									"parameters": {
										"relativeUrl": {
											"value": "activityevents?startDateTime='@{formatDateTime(getPastTime(int(item()), 'Day'), 'yyyy-MM-dd')}T00:00:00.000Z'&endDateTime='@{formatDateTime(getPastTime(int(item()), 'Day'), 'yyyy-MM-dd')}T23:59:59.999Z')",
											"type": "Expression"
										},
										"baseUrl": {
											"value": "@activity('lookup objects').output.firstRow.baseUrl",
											"type": "Expression"
										},
										"aadResource": "https://analysis.windows.net/powerbi/api"
									}
								}
							],
							"outputs": [
								{
									"referenceName": "dsAdlsManagedIdentityJson",
									"type": "DatasetReference",
									"parameters": {
										"containerName": "raw",
										"folderPath": {
											"value": "@{activity('lookup objects').output.firstRow.dataSourceName}",
											"type": "Expression"
										},
										"fileName": {
											"value": "@{activity('lookup objects').output.firstRow.objectName}-@{formatDateTime(getPastTime(int(item()), 'Day'), 'yyyy-MM-dd')}.json",
