{
	"name": "lsAsqlManagedIdentity",
	"type": "Microsoft.DataFactory/factories/linkedservices",
	"properties": {
		"description": "Azure SQL linked service connection",
		"parameters": {
			"connectionString": {
				"type": "string",
				"defaultValue": "sec-metadata-db-connection-string"
			}
		},
		"annotations": [],
		"type": "AzureSqlDatabase",
		"typeProperties": {
			"connectionString": {
				"type": "AzureKeyVaultSecret",
				"store": {
					"referenceName": "lsKeyVaultManagedIdentity",
					"type": "LinkedServiceReference"
				},
				"secretName": {
					"value": "@linkedService().connectionString",
					"type": "Expression"
				}
			}
		},
		"connectVia": {
			"referenceName": "AutoResolveIntegrationRuntime",
			"type": "IntegrationRuntimeReference"
		}
	}
}